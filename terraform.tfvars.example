# Copy to terraform.tfvars and adjust as needed. Every variable has a sensible
# default (see variables.tf), so an empty tfvars file also works.

aws_region         = "us-west-2"
availability_zones = ["us-west-2a", "us-west-2b"]

cluster_name       = "eoapi-tf-cluster"
kubernetes_version = "1.34"

node_instance_types     = ["t3.medium"]
node_group_min_size     = 2
node_group_max_size     = 3
node_group_desired_size = 2

# Set to false for one NAT gateway per AZ (more resilient, more expensive)
single_nat_gateway = true

# Pin the eoAPI chart for reproducible deploys
eoapi_chart_version = "0.13.1"

# S3 buckets the raster service may read imagery (COGs) from. Replace with your
# own bucket ARNs; the default is the public Sentinel-2 COG bucket.
eoapi_s3_bucket_arns = ["arn:aws:s3:::sentinel-cogs"]

tags = {
  Project   = "eoapi-eks-terraform"
  ManagedBy = "terraform"
}
